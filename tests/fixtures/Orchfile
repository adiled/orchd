# Minimal Orchfile for orchd integration tests.
# Two host services with varying features, one disabled.

ARG DATA_DIR=/tmp/orchd-integ-data

SERVICE postgres
RUN /usr/bin/pg_ctlcluster 15 main start --foreground
STOP /usr/bin/pg_ctlcluster 15 main stop
USER postgres
ENV PGDATA=${DATA_DIR}/postgres
HEALTHCHECK pg_isready -h 127.0.0.1 -p 5432
READINESS_TIMEOUT 30s
RESTART on-failure
RESTART_DELAY 5s

SERVICE redis
RUN /usr/bin/redis-server --port 6379
STOP /usr/bin/redis-cli shutdown
HEALTHCHECK redis-cli ping
READINESS_TIMEOUT 10s
AFTER postgres
RESTART on-failure

SERVICE disabled-svc
RUN /bin/true
DISABLED true
