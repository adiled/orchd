<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required to use Virtualization.framework (boot a VM). Granted locally
         via ad-hoc codesign; no Apple Developer account needed for dev use. -->
    <key>com.apple.security.virtualization</key>
    <true/>
</dict>
</plist>
